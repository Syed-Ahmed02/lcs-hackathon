{
  "manifest_version": 3,
  "name": "FocusFlow",
  "version": "1.0.0",
  "description": "AI-powered focus session manager that blocks distracting tabs.",

  "permissions": ["tabs", "activeTab", "storage", "scripting", "webNavigation"],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background/worker.js",
    "type": "module"
  },

  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusFlow",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["content/extractor.js", "content/overlay.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
