{
  "manifest_version": 3,
  "name": "LCS Focus",
  "description": "Focus sessions with tab awareness (dev preview)",
  "version": "0.0.1",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  }
}
